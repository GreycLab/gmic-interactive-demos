# Insert logos in selected images
# $1: Color profile for the GREYC logo (0=light logo & black outline, 1=dark logo & white outline).
# $2: Size of the logo (in % of the image height).
gw_insert_logos : skip ${1=0},${2=7.7}

  # Add GREYC logo.
  images/logo_greyc.png rs. ,{-2,round(h*$2%)} frame. 5,5,0,0,0,0
  +channels. 100% drgba.. {$1?255:0} /. 255 *.. {$1?0.75:1.5} c.. 0,255
  +dilate. 5 /. 2 max[-2,-1] a[-2,-1] c
  0 t. "https://www.greyc.fr",0,0,{-2,h/3},1,1 frame. 2,2,0
  +dilate. 5 /. 2 max. .. *.. 255 to_rgb.. a[-2,-1] c
  a[-2,-1] y,0.5
  s. c,-3 j... ..,1%,1%,0,0,1,. rm[-2,-1]

  # Add G'MIC logo.
  images/logo_gmic.png rs. ,{-2,round(h*$2%)} to_rgba.
  frame. 5,5,0,0,0,0
  s. c,-3 /. 255 *.. .
  +dilate. 5 /. 2 max[-2,-1] a[-2,-1] c
  0 t. "https://gmic.eu",0,0,{-2,h/3},1,1 frame. 2,2,0
  +dilate. 5 /. 2 max. .. *.. 255 to_rgb.. a[-2,-1] c
  a[-2,-1] y,0.5
  s. c,-3 j... ..,0.99~,1%,0,0,1,. rm[-2,-1]

  # Add CNRS / ENSICAEN / UNICAEN logos.
  images/logo_cnrs.png
  images/logo_ensicaen.png
  images/logo_unicaen.png
  rs[-3--1] ,{-4,round(h*$2%)} to_rgba[-3--1] frame[-3--1] 5,5,0,0,0,0
  if $1 a[-3--1] x else a[-3--1] y fi
  +channels. 100% drgba.. 255 +dilate. 5 /. 2 max[-2,-1] /. 255
  j... ..,{-3,[w-w#-1-16,h-h#-1-16]},0,0,1,. rm[-2,-1]

# Normalize frame.
gw_normalize_image :
  balance_gamma. 150
  n. 0,255

# Manage translation.
gw_tr_en :
  u "$1"

gw_tr_fr :
  s="$1"
  if ['$s']=='"GREYC - Interactive Warp"'
    u "GREYC - Deformation interactive"
  elif ['$s']=='"Initialize webcam: try resolution"'
    u "Initialisation de la webcam: teste r\351solution"
  elif ['$s']==['"Snapshot"']
    u "Clich\351"
  elif ['$s']==['"  Scan this QR-Code\nto download snapshot"']
    u "  Scannez ce QR-Code\npour t\351l\351charger le clich\351"
  else u $s
  fi

gw_joke :
  jokes=\
  "Oula ! t'as mauvaise mine !",\
  "Qu'est ce qu'il t'arrive ? t'es tout boursoufl\351 !",\
  "Pas assez dormi on dirait ?",\
  "Tu devrais vraiment arr\352ter avec cette nouvelle cr\350me de jour...",\
  "Tu t'es battu avec quelqu'un ?",\
  "Faudrait penser \340 arr\352ter les boissons gazeuses !",\
  "T'aurais pas un peu pris la grosse t\352te ?",\
  "Je ne sais pas si c'est \340 cause de ta nouvelle coupe de cheveux,\n mais t'as une dr\364le de t\352te !",\
  "Au secours, v'l\340 un extra-terrestre !",\
  "Pas sympa le frelon de t'avoir piqu\351 au visage...",\
  "Tu me donneras l'adresse de ton chirurgien esth\351tique !",\
  "T'es pass\351 sous un camion avant d'arriver ?",\
  "C'est pas possible d'avoir une trogne pareille !",\
  "Prends un doliprane si t'as mal au cr\342ne !",\
  "Tu ressemblais pas \340 \347a de loin !",\
  "Une vrai star de t\351l\351r\351alit\351 !",\
  "T'as de beaux yeux, tu sais !",\
  "Vous habitez chez vos parents ?",\
  "Bonjour, belle andalouse !",\
  "T'as oubli\351 de mettre ta cr\350me anti-rides ?",\
  "Ha c'est toi qui jouais dans Frankenstein !",\
  "Comme \347a, tu ressembles \340 ma belle-m\350re !",\
  "C'est fou ce que tu vieillis bien !",\
  "Tu m'excuseras de ne pas t'inviter au restaurant...",\
  "Sois honn\352te, on te fais souvent des compliments sur ton physique ?",\
  "Ne t'inqui\350te pas, c'est la beaut\351 int\351rieure qui compte le plus...",\
  "Picasso t'aurais pris comme mod\350le !",\
  "Visiblement, tu as repris le boulot toi !",\
  "Arr\352te de renifler de l'h\351lium !",\
  "Je te pr\351f\350re au naturel !",\
  "On a retrouv\351 l'acteur d'Elephant Man !",\
  "Tiens, une nouvelle esp\350ce d'humains !",\
  "Allez c'est bon, enl\350ve ton masque !"
  narg $jokes arg0 int(u(${}+1))%${},$jokes

# (End of G'MIC custom commands)
